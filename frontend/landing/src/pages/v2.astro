---
import "../styles/global.css";
import {
  hero,
  stats,
  benefits,
  criteria,
  steps,
  formBlock,
  faq,
  footer,
} from "../content";
---

<html lang="ru">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>UGC boost — EURASIAN FASHION WEEK</title>
    <link
      rel="stylesheet"
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap"
    />
    <style>
      body {
        font-family: "Inter", ui-sans-serif, system-ui, sans-serif;
      }
    </style>
  </head>
  <body class="bg-white text-neutral-900 antialiased">
    <!-- Header -->
    <header class="sticky top-0 z-40 border-b border-neutral-200 bg-white/80 backdrop-blur">
      <div class="mx-auto flex max-w-6xl items-center justify-between px-6 py-4">
        <a href="/" class="text-lg font-bold tracking-tight">UGC boost</a>
        <a
          href="#form"
          class="rounded-full bg-rose-500 px-5 py-2 text-sm font-semibold text-white transition hover:bg-rose-600"
        >
          Подать заявку
        </a>
      </div>
    </header>

    <!-- Hero -->
    <section class="relative overflow-hidden bg-gradient-to-b from-rose-50 via-amber-50 to-white">
      <div class="mx-auto grid max-w-6xl gap-12 px-6 py-24 md:grid-cols-2 md:py-32">
        <div>
          <span class="inline-block rounded-full bg-white px-4 py-1.5 text-xs font-semibold uppercase tracking-wider text-rose-600 ring-1 ring-rose-200">
            13–14 мая · Алматы
          </span>
          <h1 class="mt-6 text-5xl font-extrabold leading-tight tracking-tight md:text-6xl">
            {hero.title}
          </h1>
          <p class="mt-6 max-w-lg text-lg text-neutral-700">{hero.subtitle}</p>
          <div class="mt-10 flex flex-wrap gap-4">
            <a
              href="#form"
              class="rounded-full bg-neutral-900 px-8 py-4 text-sm font-semibold text-white transition hover:bg-neutral-800"
            >
              {hero.cta}
            </a>
            <a
              href="#how"
              class="rounded-full bg-white px-8 py-4 text-sm font-semibold text-neutral-900 ring-1 ring-neutral-300 transition hover:ring-neutral-900"
            >
              Как это работает
            </a>
          </div>
        </div>
        <div class="relative hidden md:block">
          <div class="absolute right-0 top-10 h-72 w-72 rounded-full bg-rose-200 blur-3xl opacity-60"></div>
          <div class="absolute bottom-0 right-20 h-60 w-60 rounded-full bg-amber-200 blur-3xl opacity-60"></div>
          <div class="relative flex h-full items-center justify-center">
            <div class="grid grid-cols-2 gap-4">
              <div class="rounded-3xl bg-gradient-to-br from-rose-400 to-rose-600 p-8 text-white shadow-lg">
                <p class="text-xs uppercase tracking-widest opacity-80">Подиум</p>
                <p class="mt-2 text-2xl font-bold">Главный</p>
              </div>
              <div class="mt-8 rounded-3xl bg-white p-8 shadow-lg ring-1 ring-neutral-200">
                <p class="text-xs uppercase tracking-widest text-neutral-500">Комьюнити</p>
                <p class="mt-2 text-2xl font-bold">Фэшн</p>
              </div>
              <div class="mt-8 rounded-3xl bg-neutral-900 p-8 text-white shadow-lg">
                <p class="text-xs uppercase tracking-widest opacity-60">Контент</p>
                <p class="mt-2 text-2xl font-bold">Нативный</p>
              </div>
              <div class="rounded-3xl bg-gradient-to-br from-amber-300 to-amber-500 p-8 text-white shadow-lg">
                <p class="text-xs uppercase tracking-widest opacity-80">Неделя</p>
                <p class="mt-2 text-2xl font-bold">Моды</p>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- Stats -->
    <section class="bg-white py-24">
      <div class="mx-auto max-w-6xl px-6">
        <div class="mx-auto max-w-3xl text-center">
          <h2 class="text-3xl font-extrabold tracking-tight md:text-4xl">{stats.title}</h2>
        </div>
        <div class="mt-14 grid gap-6 md:grid-cols-4">
          {
            stats.items.map((item, i) => (
              <div
                class={`rounded-3xl p-8 text-center ${
                  i % 2 === 0
                    ? "bg-gradient-to-br from-rose-50 to-rose-100"
                    : "bg-gradient-to-br from-amber-50 to-amber-100"
                }`}
              >
                <p class="text-4xl font-extrabold tracking-tight md:text-5xl">
                  {item.value}
                </p>
                <p class="mt-3 text-sm text-neutral-600">{item.label}</p>
              </div>
            ))
          }
        </div>
      </div>
    </section>

    <!-- Benefits -->
    <section class="bg-neutral-50 py-24">
      <div class="mx-auto max-w-6xl px-6">
        <div class="mx-auto max-w-3xl text-center">
          <span class="inline-block rounded-full bg-rose-100 px-4 py-1.5 text-xs font-semibold uppercase tracking-wider text-rose-600">
            Коллаборация
          </span>
          <h2 class="mt-4 text-3xl font-extrabold tracking-tight md:text-4xl">
            {benefits.title}
          </h2>
        </div>
        <ul class="mt-14 grid gap-5 md:grid-cols-2 lg:grid-cols-3">
          {
            benefits.items.map((item, i) => (
              <li class="rounded-3xl bg-white p-6 shadow-sm ring-1 ring-neutral-200 transition hover:shadow-md">
                <div class="flex items-start gap-4">
                  <span class="flex h-10 w-10 flex-shrink-0 items-center justify-center rounded-2xl bg-rose-500 text-sm font-bold text-white">
                    {i + 1}
                  </span>
                  <p class="text-sm leading-relaxed text-neutral-800">
                    {item.bold && <strong class="font-semibold">{item.bold}</strong>}{" "}
                    {item.text}
                  </p>
                </div>
              </li>
            ))
          }
        </ul>
        <p class="mt-6 text-center text-xs text-neutral-500">{benefits.disclaimer}</p>
      </div>
    </section>

    <!-- Criteria -->
    <section class="bg-white py-24">
      <div class="mx-auto grid max-w-6xl gap-12 px-6 md:grid-cols-2 md:gap-16">
        <div>
          <span class="inline-block rounded-full bg-amber-100 px-4 py-1.5 text-xs font-semibold uppercase tracking-wider text-amber-700">
            Твой профиль
          </span>
          <h2 class="mt-4 text-3xl font-extrabold tracking-tight md:text-4xl">
            {criteria.title}
          </h2>
          <p class="mt-6 text-lg text-neutral-700">{criteria.intro}</p>
          <div class="mt-6 rounded-2xl bg-amber-50 p-4 text-sm text-amber-900">
            💡 {criteria.tip}
          </div>
        </div>
        <ul class="space-y-4">
          {
            criteria.items.map((item) => (
              <li class="flex items-start gap-4 rounded-2xl bg-neutral-50 p-5">
                <span class="mt-0.5 flex h-6 w-6 flex-shrink-0 items-center justify-center rounded-full bg-rose-500 text-xs font-bold text-white">
                  ✓
                </span>
                <p class="text-neutral-800">
                  {item.bold && <strong class="font-semibold">{item.bold}</strong>}{" "}
                  {item.text}
                </p>
              </li>
            ))
          }
        </ul>
      </div>
    </section>

    <!-- Steps -->
    <section id="how" class="bg-neutral-900 py-24 text-white">
      <div class="mx-auto max-w-6xl px-6">
        <div class="mx-auto max-w-3xl text-center">
          <span class="inline-block rounded-full bg-white/10 px-4 py-1.5 text-xs font-semibold uppercase tracking-wider text-rose-300">
            5 шагов
          </span>
          <h2 class="mt-4 text-3xl font-extrabold tracking-tight md:text-4xl">
            {steps.title}
          </h2>
        </div>
        <ol class="mt-14 grid gap-6 md:grid-cols-5">
          {
            steps.items.map((step, i) => (
              <li class="relative rounded-2xl bg-white/5 p-6 ring-1 ring-white/10">
                <span class="inline-block rounded-full bg-rose-500 px-3 py-1 text-xs font-bold">
                  Шаг {i + 1}
                </span>
                <h3 class="mt-4 font-semibold leading-snug">{step.title}</h3>
                <p class="mt-2 text-sm text-neutral-400">{step.text}</p>
              </li>
            ))
          }
        </ol>
        <p class="mt-10 text-center text-xs text-neutral-500">{steps.disclaimer}</p>
      </div>
    </section>

    <!-- Form -->
    <section id="form" class="bg-gradient-to-b from-rose-50 to-white py-24">
      <div class="mx-auto max-w-2xl px-6">
        <div class="text-center">
          <h2 class="text-3xl font-extrabold tracking-tight md:text-4xl">{formBlock.title}</h2>
          <p class="mt-4 text-neutral-700">{formBlock.subtitle}</p>
        </div>

        <form id="application-form" class="mt-12 space-y-6 rounded-3xl bg-white p-8 shadow-xl ring-1 ring-neutral-200 md:p-10">
          <div class="grid gap-4 md:grid-cols-3">
            <label class="block">
              <span class="text-sm font-medium text-neutral-700">Фамилия *</span>
              <input
                required
                type="text"
                name="lastName"
                class="mt-2 w-full rounded-xl border border-neutral-300 bg-white px-4 py-3 text-sm outline-none focus:border-rose-500 focus:ring-2 focus:ring-rose-100"
              />
            </label>
            <label class="block">
              <span class="text-sm font-medium text-neutral-700">Имя *</span>
              <input
                required
                type="text"
                name="firstName"
                class="mt-2 w-full rounded-xl border border-neutral-300 bg-white px-4 py-3 text-sm outline-none focus:border-rose-500 focus:ring-2 focus:ring-rose-100"
              />
            </label>
            <label class="block">
              <span class="text-sm font-medium text-neutral-700">Отчество</span>
              <input
                type="text"
                name="middleName"
                class="mt-2 w-full rounded-xl border border-neutral-300 bg-white px-4 py-3 text-sm outline-none focus:border-rose-500 focus:ring-2 focus:ring-rose-100"
              />
            </label>
          </div>

          <label class="block">
            <span class="text-sm font-medium text-neutral-700">Номер телефона (Telegram) *</span>
            <input
              required
              type="tel"
              name="phone"
              placeholder="+7 (___) ___-__-__"
              class="mt-2 w-full rounded-xl border border-neutral-300 bg-white px-4 py-3 text-sm outline-none focus:border-rose-500 focus:ring-2 focus:ring-rose-100"
            />
            <span class="mt-1 block text-xs text-neutral-500">
              Убедитесь, что к этому номеру привязан Telegram
            </span>
          </label>

          <label class="block">
            <span class="text-sm font-medium text-neutral-700">Город проживания *</span>
            <select
              required
              name="city"
              class="mt-2 w-full rounded-xl border border-neutral-300 bg-white px-4 py-3 text-sm outline-none focus:border-rose-500 focus:ring-2 focus:ring-rose-100"
            >
              <option value="">Выбери город</option>
              {formBlock.cities.map((c) => <option value={c}>{c}</option>)}
            </select>
          </label>

          <fieldset>
            <legend class="text-sm font-medium text-neutral-700">Соцсети *</legend>
            <div class="mt-3 space-y-3">
              {
                formBlock.socials.map((s) => (
                  <div class="flex flex-col gap-2 md:flex-row md:items-center md:gap-3">
                    <label class="inline-flex items-center gap-2 rounded-xl bg-neutral-50 px-4 py-2.5 text-sm ring-1 ring-neutral-200">
                      <input
                        type="checkbox"
                        class="social-checkbox h-4 w-4 accent-rose-500"
                        data-social={s}
                      />
                      <span class="font-medium">{s}</span>
                    </label>
                    <input
                      type="url"
                      placeholder={`Ссылка на ${s}`}
                      disabled
                      data-social-input={s}
                      class="flex-1 rounded-xl border border-neutral-300 bg-white px-4 py-2.5 text-sm outline-none transition focus:border-rose-500 focus:ring-2 focus:ring-rose-100 disabled:cursor-not-allowed disabled:bg-neutral-50 disabled:opacity-50"
                    />
                  </div>
                ))
              }
            </div>
          </fieldset>

          <fieldset>
            <legend class="text-sm font-medium text-neutral-700">Категория блога (до 3) *</legend>
            <div class="mt-3 grid gap-2 md:grid-cols-2">
              {
                formBlock.categories.map((c) => (
                  <label class="inline-flex cursor-pointer items-center gap-2 rounded-xl bg-neutral-50 px-4 py-2.5 text-sm ring-1 ring-neutral-200 transition hover:ring-rose-300 has-[:checked]:bg-rose-50 has-[:checked]:ring-rose-400">
                    <input
                      type="checkbox"
                      class="category-checkbox h-4 w-4 accent-rose-500"
                      value={c}
                    />
                    <span>{c}</span>
                  </label>
                ))
              }
            </div>
          </fieldset>

          <div class="space-y-3 border-t border-neutral-200 pt-6">
            <label class="flex items-start gap-3">
              <input required type="checkbox" class="mt-0.5 h-4 w-4 accent-rose-500" />
              <span class="text-sm text-neutral-700">
                Я принимаю условия{" "}
                <a href="/legal/user-agreement" class="text-rose-600 underline">
                  Пользовательского соглашения
                </a>
              </span>
            </label>
            <label class="flex items-start gap-3">
              <input required type="checkbox" class="mt-0.5 h-4 w-4 accent-rose-500" />
              <span class="text-sm text-neutral-700">
                Даю согласие на обработку персональных данных в соответствии с{" "}
                <a href="/legal/privacy-policy" class="text-rose-600 underline">
                  Политикой
                </a>
              </span>
            </label>
          </div>

          <button
            type="submit"
            class="w-full rounded-xl bg-rose-500 px-6 py-4 font-semibold text-white transition hover:bg-rose-600"
          >
            {formBlock.submitLabel}
          </button>
        </form>
      </div>
    </section>

    <!-- FAQ -->
    <section class="bg-white py-24">
      <div class="mx-auto max-w-3xl px-6">
        <h2 class="mb-12 text-center text-3xl font-extrabold tracking-tight md:text-4xl">
          {faq.title}
        </h2>
        <div class="space-y-3">
          {
            faq.items.map((item) => (
              <details class="group rounded-2xl bg-neutral-50 p-6 ring-1 ring-neutral-200 transition open:bg-white open:shadow-md open:ring-rose-200">
                <summary class="flex cursor-pointer items-center justify-between gap-4 text-lg font-semibold">
                  <span>{item.q}</span>
                  <span class="flex h-8 w-8 flex-shrink-0 items-center justify-center rounded-full bg-rose-500 text-white transition group-open:rotate-45">
                    +
                  </span>
                </summary>
                <p class="mt-4 leading-relaxed text-neutral-700">{item.a}</p>
              </details>
            ))
          }
        </div>
      </div>
    </section>

    <!-- Footer -->
    <footer class="bg-neutral-950 text-neutral-400">
      <div class="mx-auto grid max-w-6xl gap-10 px-6 py-16 md:grid-cols-3">
        <div>
          <p class="text-xl font-bold text-white">{footer.brand}</p>
          <p class="mt-2 text-sm">{footer.tagline}</p>
        </div>
        <div class="space-y-2 text-sm">
          <p>{footer.legalEntity}</p>
          {footer.links.map((l) => (
            <a href={l.href} class="block transition hover:text-white">
              {l.label}
            </a>
          ))}
        </div>
        <div class="space-y-2 text-sm">
          <p>Телефон: <span class="text-white">{footer.phone}</span></p>
          <p>
            Instagram:{" "}
            <a href={footer.instagram.href} class="text-rose-400 hover:text-rose-300">
              {footer.instagram.label}
            </a>
          </p>
        </div>
      </div>
      <div class="border-t border-white/10">
        <div class="mx-auto max-w-6xl px-6 py-6 text-xs">{footer.copyright}</div>
      </div>
    </footer>

    <script>
      document.querySelectorAll<HTMLInputElement>(".social-checkbox").forEach((cb) => {
        cb.addEventListener("change", () => {
          const name = cb.dataset.social!;
          const input = document.querySelector<HTMLInputElement>(
            `[data-social-input="${name}"]`,
          );
          if (!input) return;
          if (cb.checked) {
            input.disabled = false;
            input.required = true;
          } else {
            input.disabled = true;
            input.required = false;
            input.value = "";
          }
        });
      });

      const categoryBoxes = document.querySelectorAll<HTMLInputElement>(".category-checkbox");
      categoryBoxes.forEach((cb) => {
        cb.addEventListener("change", () => {
          const checked = Array.from(categoryBoxes).filter((c) => c.checked);
          categoryBoxes.forEach((c) => {
            if (!c.checked && checked.length >= 3) c.disabled = true;
            else c.disabled = false;
          });
        });
      });

      document.getElementById("application-form")?.addEventListener("submit", (e) => {
        e.preventDefault();
        alert("Заявка отправлена (демо)\n\nВ проде тут успех-экран с CTA в Telegram-бот.");
      });
    </script>
  </body>
</html>
